        <!-- VPC ENDPOINTS BOX                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="130" value="&lt;b&gt;VPC Endpoints  (Interface unless noted)&lt;/b&gt;&lt;br&gt;Private connectivity — avoids NAT Gateway charges for AWS services"
