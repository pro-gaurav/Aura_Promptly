        <!-- SECURITY GROUPS LEGEND                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="900" value="&lt;b&gt;Security Groups Summary&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-alb (ALB):&lt;/b&gt;&lt;br&gt;  IN: 443 from 0.0.0.0/0 (API GW managed SG)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-ecs (ECS tasks):&lt;/b&gt;&lt;br&gt;  IN: 4000 from sg-alb&lt;br&gt;  OUT: 443 to VPC endpoints (Bedrock, Secrets, ECR, logs)&lt;br&gt;  OUT: 443 to NAT GW (OpenAI, Vertex, Grafana)&lt;br&gt;  OUT: 5432 to sg-aurora&lt;br&gt;  OUT: 6379 to sg-redis&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-aurora:&lt;/b&gt;&lt;br&gt;  IN: 5432 from sg-ecs&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-redis:&lt;/b&gt;&lt;br&gt;  IN: 6379 from sg-ecs&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-vpc-endpoints:&lt;/b&gt;&lt;br&gt;  IN: 443 from sg-ecs"
