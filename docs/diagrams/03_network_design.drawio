      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="9" value="&lt;b&gt;Aura Promptly — Network Design (v1.1)&lt;/b&gt;&lt;br&gt;Hub VPC Topology · VPC Endpoints · Spoke Connectivity"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=#24292E;fontColor=#FFFFFF;strokeColor=none;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1820" height="50" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- INTERNET CLOUD (top)                                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="10" value="&lt;b&gt;Internet&lt;/b&gt;&lt;br&gt;(Public internet — HTTPS/443 only)"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="700" y="70" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- External services reachable from hub (via NAT) -->
        <mxCell id="11" value="&lt;b&gt;OpenAI API&lt;/b&gt;&lt;br&gt;api.openai.com"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00A67E;strokeColor=#007A5E;fontColor=#FFFFFF;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="150" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="12" value="&lt;b&gt;Vertex AI&lt;/b&gt;&lt;br&gt;aiplatform.googleapis.com"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4285F4;strokeColor=#2956A3;fontColor=#FFFFFF;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="1350" y="80" width="170" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="13" value="&lt;b&gt;Grafana Cloud&lt;/b&gt;&lt;br&gt;(optional · OTel export)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0820F;strokeColor=#B85A00;fontColor=#FFFFFF;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="1560" y="80" width="170" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="14" value="&lt;b&gt;AWS STS&lt;/b&gt;&lt;br&gt;sts.amazonaws.com&lt;br&gt;(GCP spoke OIDC exchange)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="165" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HUB VPC                                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="100" value="&lt;b&gt;Hub VPC  10.0.0.0/16  (us-east-1)&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8F0;strokeColor=#FF9900;strokeWidth=3;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="1400" height="720" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- PUBLIC SUBNETS (2 AZs)                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="110" value="&lt;b&gt;Public Subnets&lt;/b&gt;  ·  10.0.1.0/24 (AZ-a)  ·  10.0.2.0/24 (AZ-b)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="250" width="1350" height="195" as="geometry"/>
        </mxCell>

        <!-- Internet Gateway -->
        <mxCell id="111" value="&lt;b&gt;Internet Gateway&lt;/b&gt;&lt;br&gt;Attached to VPC&lt;br&gt;Enables public subnet internet routing"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="245" y="293" width="195" height="80" as="geometry"/>
        </mxCell>

        <!-- NAT Gateway -->
        <mxCell id="112" value="&lt;b&gt;NAT Gateway&lt;/b&gt;&lt;br&gt;In public subnet&lt;br&gt;EIP attached&lt;br&gt;Private subnets route&lt;br&gt;0.0.0.0/0 here&lt;br&gt;~$32/mo + data charges"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="470" y="285" width="180" height="110" as="geometry"/>
        </mxCell>

        <!-- ALB -->
        <mxCell id="113" value="&lt;b&gt;Application Load Balancer&lt;/b&gt;&lt;br&gt;Internal (not internet-facing)&lt;br&gt;Spans both AZs&lt;br&gt;Port 80 → LiteLLM:4000&lt;br&gt;Port 4001 → Admin UI&lt;br&gt;Target: ECS Fargate tasks"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="685" y="285" width="270" height="120" as="geometry"/>
        </mxCell>

        <!-- API Gateway note -->
        <mxCell id="114" value="&lt;b&gt;API Gateway&lt;/b&gt;&lt;br&gt;Regional endpoint&lt;br&gt;Outside VPC (managed)&lt;br&gt;Routes to internal ALB&lt;br&gt;via VPC Link"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="990" y="290" width="190" height="100" as="geometry"/>
        </mxCell>

        <!-- WAF note -->
        <mxCell id="115" value="&lt;b&gt;WAF WebACL&lt;/b&gt;&lt;br&gt;Attached to API GW&lt;br&gt;OWASP + rate-limit"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="1210" y="300" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- PRIVATE SUBNETS                                     -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="120" value="&lt;b&gt;Private Subnets&lt;/b&gt;  ·  10.0.10.0/24 (AZ-a)  ·  10.0.11.0/24 (AZ-b)&lt;br&gt;Route table: 0.0.0.0/0 → NAT Gateway  ·  AWS services → VPC Endpoints"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F0FF;strokeColor=#0050C8;strokeWidth=2;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="463" width="1350" height="435" as="geometry"/>
        </mxCell>

        <!-- ECS Fargate -->
        <mxCell id="121" value="&lt;b&gt;ECS Fargate Tasks&lt;/b&gt;&lt;br&gt;LiteLLM Proxy&lt;br&gt;0.25 vCPU · 512 MB&lt;br&gt;OTel Collector (sidecar)&lt;br&gt;SG: allow 4000 from ALB"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="245" y="510" width="235" height="110" as="geometry"/>
        </mxCell>

        <!-- Aurora Serverless -->
        <mxCell id="122" value="&lt;b&gt;Aurora Serverless v2&lt;/b&gt;&lt;br&gt;(PostgreSQL + pgvector)&lt;br&gt;Multi-AZ cluster&lt;br&gt;Schema: litellm + bedrock_kb&lt;br&gt;SG: allow 5432 from ECS SG&lt;br&gt;Auto-pause: 5 min inactivity"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="510" y="510" width="270" height="120" as="geometry"/>
        </mxCell>

        <!-- ElastiCache Redis -->
        <mxCell id="123" value="&lt;b&gt;ElastiCache Redis&lt;/b&gt;&lt;br&gt;cache.t4g.micro&lt;br&gt;Single AZ (PoC)&lt;br&gt;SG: allow 6379 from ECS SG"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="815" y="510" width="220" height="100" as="geometry"/>
        </mxCell>

