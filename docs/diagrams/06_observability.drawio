        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="100" value="&lt;b&gt;LAYER 1: CloudWatch  (Always-on · No data egress · Zero additional cost for PoC volume)&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2E8;strokeColor=#FF9900;strokeWidth=3;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;"
          vertex="1" parent="1">
