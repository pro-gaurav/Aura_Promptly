        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LAYER 2: OTEL → GRAFANA CLOUD (Optional)           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="200" value="&lt;b&gt;LAYER 2: OTel → Grafana Cloud  (Optional · Terraform toggle: enable_grafana_export = true)&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCCCFF;strokeColor=#6666CC;strokeWidth=3;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="1820" height="310" as="geometry"/>
        </mxCell>

        <!-- OTel Collector -->
        <mxCell id="201" value="&lt;b&gt;OTel Collector (ECS sidecar)&lt;/b&gt;&lt;br&gt;Receives from:&lt;br&gt;· LiteLLM OTLP exporter&lt;br&gt;· CloudWatch metric stream&lt;br&gt;&lt;br&gt;Processors:&lt;br&gt;· Batch (reduce API calls)&lt;br&gt;· Resource (add env labels)&lt;br&gt;· Tail-based trace sampler&lt;br&gt;&lt;br&gt;Config: YAML in ECS task def&lt;br&gt;Vendor-neutral pipeline"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCCCFF;strokeColor=#6666CC;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="675" width="280" height="230" as="geometry"/>
        </mxCell>

        <!-- Grafana Loki -->
        <mxCell id="202" value="&lt;b&gt;Grafana Cloud Loki&lt;/b&gt;&lt;br&gt;Log storage + search&lt;br&gt;50 GB/month (free tier)&lt;br&gt;14-day retention&lt;br&gt;&lt;br&gt;Labels: model · team · env&lt;br&gt;LogQL queries supported&lt;br&gt;Correlate with traces"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0820F;strokeColor=#B85A00;fontColor=#FFFFFF;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="390" y="675" width="230" height="170" as="geometry"/>
        </mxCell>

        <!-- Grafana Tempo -->
        <mxCell id="203" value="&lt;b&gt;Grafana Cloud Tempo&lt;/b&gt;&lt;br&gt;Distributed tracing&lt;br&gt;Trace: spoke → API GW → LiteLLM&lt;br&gt;→ Bedrock (inferred)&lt;br&gt;&lt;br&gt;TraceQL queries&lt;br&gt;Span durations by component&lt;br&gt;P99 latency breakdown"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0820F;strokeColor=#B85A00;fontColor=#FFFFFF;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="640" y="675" width="230" height="170" as="geometry"/>
        </mxCell>

        <!-- Grafana Prometheus -->
        <mxCell id="204" value="&lt;b&gt;Grafana Cloud Prometheus&lt;/b&gt;&lt;br&gt;Metrics (remote-write)&lt;br&gt;10k active series (free tier)&lt;br&gt;&lt;br&gt;Same 4 dashboard metrics&lt;br&gt;as CloudWatch (identical views)&lt;br&gt;PromQL queries&lt;br&gt;Recording rules for cost"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0820F;strokeColor=#B85A00;fontColor=#FFFFFF;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="890" y="675" width="230" height="170" as="geometry"/>
        </mxCell>

        <!-- Grafana Dashboards (Layer 2) -->
        <mxCell id="205" value="&lt;b&gt;Grafana Dashboards  (same 4 views as CloudWatch + richer visualisations for YouTube/LinkedIn demos)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Dashboards are provisioned via Grafana Terraform provider.  API token stored in Secrets Manager — never in git (ADR-12 public repo security)."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6666CC;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="1150" y="675" width="680" height="100" as="geometry"/>
        </mxCell>

        <!-- Toggle note -->
        <mxCell id="206" value="&lt;b&gt;Vendor-Neutral Pipeline Note:&lt;/b&gt;&lt;br&gt;Same OTel Collector config can target Datadog, Splunk, Azure Monitor, or New Relic by changing the exporter endpoint and API key.&lt;br&gt;No application code changes required.  Toggle enable_grafana_export=false to disable completely."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4285F4;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="1150" y="795" width="680" height="100" as="geometry"/>
