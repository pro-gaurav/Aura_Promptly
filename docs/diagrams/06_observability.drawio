        <!-- CloudWatch Alarms -->
        <mxCell id="103" value="&lt;b&gt;CloudWatch Alarms&lt;/b&gt;&lt;br&gt;Alarm 1: ErrorRate &gt; 5% (5-min window)&lt;br&gt;Alarm 2: P95Latency &gt; 5s&lt;br&gt;Alarm 3: SpendDaily &gt; $10 threshold&lt;br&gt;Alarm 4: GuardrailBlocks &gt; 10/hr&lt;br&gt;&lt;br&gt;Action: SNS → email notification"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=9;align=left;"
