        </mxCell>

        <!-- CloudWatch Logs -->
        <mxCell id="101" value="&lt;b&gt;CloudWatch Logs&lt;/b&gt;&lt;br&gt;Log group: /aura-promptly/litellm&lt;br&gt;/aura-promptly/apigw&lt;br&gt;/aura-promptly/ecs&lt;br&gt;Retention: 30 days (PoC)&lt;br&gt;Log Insights queries available"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="285" width="250" height="120" as="geometry"/>
        </mxCell>

        <!-- EMF → Metrics -->
        <mxCell id="102" value="&lt;b&gt;CloudWatch Metrics (EMF)&lt;/b&gt;&lt;br&gt;Namespace: AuraPromptly&lt;br&gt;Dimensions: model · team_id&lt;br&gt;&lt;br&gt;Custom metrics:&lt;br&gt;· RequestCount · ErrorCount&lt;br&gt;· P50/P95/P99 Latency&lt;br&gt;· TokensIn · TokensOut&lt;br&gt;· CostEstimate · BlockedRequests"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#CC7A00;fontColor=#000000;fontSize=9;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="340" y="285" width="270" height="150" as="geometry"/>
